# --- Backend del LLM: "ollama" (por defecto) o "deepseek" ---
LLM_BACKEND=ollama

# --- Opción A: Ollama (recomendada). Local o cloud. ---
# Modelo: cloud (ej. minimax-m3:cloud) o local (ej. llama3.1).
# Para los modelos *:cloud necesitas una cuenta de Ollama: ejecuta `ollama signin`.
OLLAMA_MODEL=minimax-m3:cloud
# Host de Ollama; déjalo vacío para usar el por defecto (http://localhost:11434).
# OLLAMA_HOST=http://localhost:11434

# --- Opción B: DeepSeek (API en la nube). Pon LLM_BACKEND=deepseek para usarlo. ---
# Consigue tu API key en https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
